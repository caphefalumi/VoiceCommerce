<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mobi_pulse_background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Login Prompt (shown when not logged in) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/loginPromptCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="24dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/mobi_pulse_outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <ImageView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:src="@drawable/ic_profile"
                        android:contentDescription="@string/profile_desc"
                        app:tint="@color/mobi_pulse_on_surface_variant" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:text="@string/login_prompt_title"
                        android:textColor="@color/mobi_pulse_on_surface"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter"
                        android:gravity="center"
                        android:text="@string/login_prompt_message"
                        android:textColor="@color/mobi_pulse_on_surface_variant"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/loginPromptButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:text="@string/login"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/registerPromptButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:text="@string/register_account"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Profile Content (shown when logged in) -->
            <LinearLayout
                android:id="@+id/profileContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <!-- Hero Header with Gradient -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/bg_profile_header_gradient">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingBottom="24dp"
                    android:paddingTop="48dp">

                    <!-- Avatar -->
                    <FrameLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:cardCornerRadius="36dp"
                            app:cardElevation="4dp"
                            app:strokeColor="#40FFFFFF"
                            app:strokeWidth="2dp">

                            <ImageView
                                android:id="@+id/avatarImage"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@color/mobi_pulse_primary"
                                android:scaleType="centerCrop"
                                android:contentDescription="@string/profile_desc"
                                android:src="@drawable/ic_profile" />

                        </com.google.android.material.card.MaterialCardView>

                    </FrameLayout>

                    <!-- User Info -->
                    <TextView
                        android:id="@+id/userNameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/userEmailText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/inter"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp" />

                </LinearLayout>

            </FrameLayout>

            <!-- Stats Row -->
            <LinearLayout
                android:id="@+id/statsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-20dp"
                android:background="@drawable/bg_card_white_rounded"
                android:elevation="4dp"
                android:orientation="horizontal">

                <!-- Orders Stat -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/orderCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:text="0"
                        android:textColor="@color/mobi_pulse_on_surface"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/orders"
                        android:textColor="@color/mobi_pulse_on_surface_variant"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/mobi_pulse_outline_variant"
                    android:layout_marginVertical="12dp" />

                <!-- Reviews Stat -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/reviewCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:text="0"
                        android:textColor="@color/mobi_pulse_on_surface"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/reviews_label"
                        android:textColor="@color/mobi_pulse_on_surface_variant"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Section: My Orders -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/space_grotesk_bold"
                android:text="@string/my_orders"
                android:textColor="@color/mobi_pulse_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Order Status Cards Row -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <include layout="@layout/item_order_status_card"
                        android:id="@+id/statusPendingCard" />
                    <include layout="@layout/item_order_status_card"
                        android:id="@+id/statusPreparingCard" />
                    <include layout="@layout/item_order_status_card"
                        android:id="@+id/statusShippedCard" />
                    <include layout="@layout/item_order_status_card"
                        android:id="@+id/statusDeliveredCard" />

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Recent Orders List -->
            <LinearLayout
                android:id="@+id/ordersRow"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/space_grotesk_bold"
                    android:text="@string/order_history"
                    android:textColor="@color/mobi_pulse_on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right"
                            android:contentDescription="@string/cd_chevron_right"
                            app:tint="@color/mobi_pulse_on_surface_variant" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/ordersRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

            <!-- Section: Account Settings -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/space_grotesk_bold"
                android:text="@string/account_settings"
                android:textColor="@color/mobi_pulse_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Settings Menu Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/mobi_pulse_outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Profile Row -->
                    <LinearLayout
                        android:id="@+id/editProfileRow"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_profile"
                            android:contentDescription="@string/profile_desc"
                            app:tint="@color/mobi_pulse_on_surface_variant" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:fontFamily="@font/inter"
                            android:text="@string/edit_profile"
                            android:textColor="@color/mobi_pulse_on_surface"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right"
                            android:contentDescription="@string/cd_chevron_right"
                            app:tint="@color/mobi_pulse_on_surface_variant" />

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/mobi_pulse_outline_variant" android:layout_marginStart="56dp" />

                    <!-- Notifications Row -->
                    <LinearLayout
                        android:id="@+id/notificationsRow"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_notification"
                            android:contentDescription="@string/notifications"
                            app:tint="@color/mobi_pulse_on_surface_variant" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:fontFamily="@font/inter"
                            android:text="@string/notifications"
                            android:textColor="@color/mobi_pulse_on_surface"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right"
                            android:contentDescription="@string/cd_chevron_right"
                            app:tint="@color/mobi_pulse_on_surface_variant" />

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/mobi_pulse_outline_variant" android:layout_marginStart="56dp" />

                    <!-- Language / Support Row -->
                    <LinearLayout
                        android:id="@+id/helpCenterRow"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_support"
                            android:contentDescription="@string/help_center"
                            app:tint="@color/mobi_pulse_on_surface_variant" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:fontFamily="@font/inter"
                            android:text="@string/help_center"
                            android:textColor="@color/mobi_pulse_on_surface"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right"
                            android:contentDescription="@string/cd_chevron_right"
                            app:tint="@color/mobi_pulse_on_surface_variant" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Logout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/logoutButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/space_grotesk_bold"
                android:text="@string/logout"
                android:textAllCaps="false"
                android:textColor="@color/error"
                android:textSize="15sp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_logout"
                app:iconGravity="textStart"
                app:iconTint="@color/error"
                app:strokeColor="@color/error" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
