<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mobi_pulse_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="24dp"
        android:clipToPadding="false">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_grotesk_bold"
            android:text="@string/category_explore_title"
            android:textColor="@color/mobi_pulse_on_surface"
            android:textSize="32sp"
            android:textStyle="bold" />

        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_badge"
            android:backgroundTint="@color/mobi_pulse_primary" />

        <!-- Main Category Grid (3 columns) -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="2"
            android:useDefaultMargins="true"
            android:layout_marginBottom="32dp">

            <!-- Item 1: Điện thoại -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCategoryPhones"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/mobi_pulse_outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_search_bar"
                        android:backgroundTint="#F2F4F7"
                        android:padding="12dp"
                        android:src="@drawable/ic_category"
                        android:contentDescription="@string/cd_category_phones"
                        app:tint="@color/mobi_pulse_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/category_phones"
                        android:textColor="@color/mobi_pulse_on_surface"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_phones_count"
                        android:textColor="@color/mobi_pulse_on_surface_variant"
                        android:textSize="8sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Item 2: Laptop -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCategoryLaptops"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/mobi_pulse_outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_search_bar"
                        android:backgroundTint="#F2F4F7"
                        android:padding="12dp"
                        android:src="@drawable/ic_category"
                        android:contentDescription="@string/cd_category_laptops"
                        app:tint="@color/mobi_pulse_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/category_laptops"
                        android:textColor="@color/mobi_pulse_on_surface"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_laptops_count"
                        android:textColor="@color/mobi_pulse_on_surface_variant"
                        android:textSize="8sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Item 3: Tablet -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCategoryTablets"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/mobi_pulse_outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_search_bar"
                        android:backgroundTint="#F2F4F7"
                        android:padding="12dp"
                        android:src="@drawable/ic_category"
                        android:contentDescription="@string/cd_category_tablets"
                        app:tint="@color/mobi_pulse_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/category_tablets"
                        android:textColor="@color/mobi_pulse_on_surface"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_tablets_count"
                        android:textColor="@color/mobi_pulse_on_surface_variant"
                        android:textSize="8sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Item 4: Apple -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCategoryApple"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#FFE177"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/mobi_pulse_primary"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:color/white"
                        android:padding="12dp"
                        android:src="@drawable/ic_category"
                        android:contentDescription="@string/cd_category_apple"
                        app:tint="@color/mobi_pulse_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/category_phones"
                        android:textColor="@color/mobi_pulse_on_surface"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_new"
                        android:textColor="@color/mobi_pulse_on_surface_variant"
                        android:textSize="8sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Item 5: Phụ kiện -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCategoryAccessories"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/mobi_pulse_outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_search_bar"
                        android:backgroundTint="#F2F4F7"
                        android:padding="12dp"
                        android:src="@drawable/ic_bolt"
                        android:contentDescription="@string/cd_category_accessories"
                        app:tint="@color/mobi_pulse_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/category_accessories"
                        android:textColor="@color/mobi_pulse_on_surface"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_accessories_count"
                        android:textColor="@color/mobi_pulse_on_surface_variant"
                        android:textSize="8sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Item 6: Samsung -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCategorySamsung"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/mobi_pulse_outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_search_bar"
                        android:backgroundTint="#F2F4F7"
                        android:padding="12dp"
                        android:src="@drawable/ic_category"
                        android:contentDescription="@string/cd_category_samsung"
                        app:tint="@color/mobi_pulse_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter"
                        android:text="SAMSUNG"
                        android:textColor="@color/mobi_pulse_on_surface"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_samsung_sale"
                        android:textColor="@color/mobi_pulse_on_surface_variant"
                        android:textSize="8sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- Brands Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/category_brands_title"
                android:fontFamily="@font/space_grotesk_bold"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/mobi_pulse_on_surface" />

            <TextView
                android:id="@+id/textSeeAllBrands"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_see_all"
                android:textColor="@color/mobi_pulse_primary"
                android:textStyle="bold"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginBottom="32dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBrandApple"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/mobi_pulse_outline_variant"
                app:strokeWidth="1dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Apple"
                    android:gravity="center"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/mobi_pulse_on_surface" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBrandSamsung"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/mobi_pulse_outline_variant"
                app:strokeWidth="1dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Samsung"
                    android:gravity="center"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/mobi_pulse_on_surface" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBrandOppo"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/mobi_pulse_outline_variant"
                app:strokeWidth="1dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Oppo"
                    android:gravity="center"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/mobi_pulse_on_surface" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBrandXiaomi"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/mobi_pulse_outline_variant"
                app:strokeWidth="1dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Xiaomi"
                    android:gravity="center"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/mobi_pulse_on_surface" />
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- iFans Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/category_ifans_title"
            android:fontFamily="@font/space_grotesk_bold"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/mobi_pulse_on_surface"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPromoIFans"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/mobi_pulse_primary_container"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_ifans_promo_title"
                        android:textColor="@color/mobi_pulse_on_surface_variant"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_ifans_promo_subtitle"
                        android:textColor="@color/mobi_pulse_on_surface"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/category_ifans_promo_desc"
                        android:textColor="@color/mobi_pulse_on_surface_variant"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="match_parent"
                    android:layout_alignParentEnd="true"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_category"
                    android:contentDescription="@string/cd_iphone_promo"
                    app:tint="@color/mobi_pulse_primary" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginBottom="32dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProductAppleWatch"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/mobi_pulse_outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="bottom">
                    
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_bolt"
                        android:contentDescription="@string/cd_apple_watch"
                        app:tint="@color/mobi_pulse_primary" />
                         
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="APPLE WATCH"
                        android:textStyle="bold"
                        android:textSize="10sp"
                        android:textColor="@color/mobi_pulse_on_surface" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Series 9 | Ultra 2"
                        android:textSize="8sp"
                        android:textColor="@color/mobi_pulse_on_surface_variant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProductMacBook"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/mobi_pulse_outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="bottom">
                    
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_category"
                        android:contentDescription="@string/cd_macbook"
                        app:tint="@color/mobi_pulse_primary" />
                         
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="MACBOOK"
                        android:textStyle="bold"
                        android:textSize="10sp"
                        android:textColor="@color/mobi_pulse_on_surface" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Air M2 | Pro M3"
                        android:textSize="8sp"
                        android:textColor="@color/mobi_pulse_on_surface_variant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- Bottom Link -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewAllCategories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/category_view_all"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/mobi_pulse_outline_variant"
            android:textColor="@color/mobi_pulse_primary"
            android:textSize="10sp"
            android:textStyle="bold"
            app:cornerRadius="100dp"
            app:icon="@drawable/ic_chevron_right"
            app:iconGravity="end"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"
            android:layout_marginBottom="40dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" /> <!-- Bottom padding -->

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
