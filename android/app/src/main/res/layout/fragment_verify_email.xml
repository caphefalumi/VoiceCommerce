<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mobi_pulse_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp">

        <!-- Icon -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iconCard"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="40dp"
            app:cardBackgroundColor="#FEE2E2">
            <ImageView
                android:id="@+id/statusIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mail"
                app:tint="#DC2626" />
            <ProgressBar
                android:id="@+id/loadingIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:indeterminateTint="#DC2626"
                android:visibility="gone" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/space_grotesk_bold"
            android:text="Xác minh email"
            android:textColor="@color/mobi_pulse_on_surface"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/messageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:fontFamily="@font/inter"
            android:text="Đang xác minh email của bạn..."
            android:textColor="@color/mobi_pulse_on_surface_variant"
            android:textSize="15sp" />

        <!-- Success card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/successCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            app:cardBackgroundColor="#F0FFF4"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#9AE6B4"
            app:strokeWidth="1dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:padding="16dp"
                android:text="Email của bạn đã được xác minh thành công!"
                android:textColor="#22543D"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Error card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/errorCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            app:cardBackgroundColor="#FFF5F5"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#FFCDD2"
            app:strokeWidth="1dp">
            <TextView
                android:id="@+id/errorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:padding="16dp"
                android:textColor="#C62828"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Action button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/actionButton"
            style="@style/Widget.TGDD.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:visibility="gone"
            android:fontFamily="@font/space_grotesk_bold"
            android:text="Tiến hành đăng nhập"
            android:textSize="16sp" />

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
