<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TGDD">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.TGDD">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep link: tgdd://reset-password?token=xxx -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="tgdd"
                    android:host="reset-password" />
            </intent-filter>
            <!-- Deep link: tgdd://verify-email?token=xxx -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="tgdd"
                    android:host="verify-email" />
            </intent-filter>
            <!-- Deep link: tgdd://checkout?session_id=xxx -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="tgdd"
                    android:host="checkout" />
            </intent-filter>
        </activity>

        <!-- Handles the OAuth callback redirect from the browser -->
        <activity
            android:name=".ui.auth.OAuthCallbackActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.TGDD">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- Matches https://api-worker.dangduytoan13l.workers.dev/api/auth/callback/google -->
                <data
                    android:scheme="tgdd"
                    android:host="oauth" />
            </intent-filter>
        </activity>
    </application>

</manifest>
