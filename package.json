{
  "name": "tgdd-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun --cwd apps/web run dev",
    "build:web": "bun --cwd apps/web run build",
    "dev:ai": "bun --cwd apps/ai-worker run dev",
    "deploy:ai": "bun --cwd apps/ai-worker run deploy",
    "dev:api": "bun --cwd apps/api-worker run dev",
    "deploy:api": "bun --cwd apps/api-worker run deploy",
    "lint": "bun x oxlint apps/*/src",
    "format": "bun x oxfmt --config apps/web/.oxfmtrc.jsonc ."
  }
}
